---

<div id="stepsContainer"></div>

<script define:vars={{ stepsData }}>
  var container = document.getElementById('stepsContainer');
  stepsData.forEach(function(step) {
    var section = document.createElement('div');
    section.className = 'step-card';
    section.dataset.step = step.id;
    section.dataset.title = step.title;
    section.innerHTML = '<div class="max-w-[700px] mx-auto">' +
      '<div class="mb-6">' +
        '<div class="flex items-center gap-3 mb-4">' +
          '<div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-indigo-500 to-indigo-600 dark:from-indigo-600 dark:to-indigo-700">' +
            '<span class="text-white font-bold text-lg">' + step.id + '</span>' +
          '</div>' +
        '</div>' +
        '<h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">' + step.title + '</h2>' +
      '</div>' +
      '<div class="space-y-4">' +
        step.content +
      '</div>' +
    '</div>';
    container.appendChild(section);
  });
</script>