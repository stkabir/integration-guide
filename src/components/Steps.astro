$keyPath = [Environment]::GetEnvironmentVariable("GOOGLE_SERVICE_ACCOUNT_KEY_FILE", "User")
if (-not $keyPath -or -not (Test-Path $keyPath)) { Write-Host "[ERROR]" -ForegroundColor Red; return }
$json = Get-Content $keyPath | ConvertFrom-Json
Write-Host "[OK] Service Account: $($json.client_email)" -ForegroundColor Green</pre>
