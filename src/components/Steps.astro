---

<div class="steps-container" id="stepsContainer"></div>

<script define:vars={{ stepsData }}>
  const container = document.getElementById('stepsContainer');
  stepsData.forEach(step => {
    const section = document.createElement('section');
    section.className = 'step';
    section.dataset.step = step.id;
    section.innerHTML = `
      <div class="step-header">
        <div class="step-icon">${step.icon}</div>
        <div class="step-info">
          <span class="step-label">Paso ${step.id}</span>
          <h2>${step.title}</h2>
        </div>
      </div>
      <div class="step-content">${step.content}</div>
    `;
    container.appendChild(section);
  });
</script>

<style>
  .steps-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .step {
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .step:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    color: white;
  }

  .step-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    font-weight: 700;
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .step-info {
    flex: 1;
    min-width: 0;
  }

  .step-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.9;
    display: block;
  }

  .step-info h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 0.125rem;
    color: white;
  }

  .step-content {
    padding: 1.5rem;
  }

  .step-content h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.75rem;
    color: #1e293b;
  }

  .step-content h3:first-child {
    margin-top: 0;
  }

  .step-content p {
    margin-bottom: 0.75rem;
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .step-content ol,
  .step-content ul {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .step-content li {
    margin-bottom: 0.5rem;
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .info-box {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
    border: 1px solid #bae6fd;
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .info-box h3 {
    margin-top: 0;
    color: #0369a1;
    font-size: 0.9rem;
  }

  .info-box p {
    margin-bottom: 0;
    color: #0c4a6e;
  }

  .warning-box {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border: 1px solid #fcd34d;
    border-radius: 12px;
    padding: 1rem;
    margin: 1rem 0;
  }

  .warning-box h4 {
    margin-top: 0;
    color: #b45309;
    font-size: 0.9rem;
  }

  .warning-box p {
    margin-bottom: 0;
    color: #92400e;
  }

  .step-content a {
    color: #6366f1;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .step-content a:hover {
    color: #4f46e5;
    text-decoration: underline;
  }

  .code-block {
    display: block;
  }

  @media (max-width: 640px) {
    .step-header {
      padding: 1rem;
    }

    .step-icon {
      width: 2.5rem;
      height: 2.5rem;
      font-size: 1rem;
    }

    .step-info h2 {
      font-size: 1rem;
    }

    .step-content {
      padding: 1rem;
    }
  }
</style>