---
import Layout from '../layouts/Layout.astro';
import Steps from '../components/Steps.astro';
---

<Layout title="Guía de Instalación - OpenCode + MiniMax.io + Slack + Google Calendar/Sheets">
  <div class="h-screen flex flex-col">
    <nav class="h-[60px] flex items-center justify-center px-5 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700 flex-shrink-0 relative">
      <div class="absolute left-5 flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-indigo-600 dark:from-indigo-600 dark:to-indigo-700 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 01-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.107-1.204l-.527-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h1 class="text-xl font-bold text-slate-900 dark:text-white">
          Guía de Instalación
        </h1>
      </div>

      <a
        href="https://wa.me/5219981090161?text=Hola%2C%20tengo%20una%20duda%20sobre%20la%20gu%C3%ADa%20de%20instalaci%C3%B3n"
        target="_blank"
        class="flex items-center gap-2 px-4 py-2 rounded-lg bg-emerald-500 hover:bg-emerald-600 transition-colors text-white"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span class="text-sm font-medium">Ayuda</span>
      </a>

      <button
        type="button"
        id="themeToggle"
        class="absolute right-5 flex items-center justify-center w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors duration-200"
        aria-label="Cambiar tema"
      >
        <svg class="w-5 h-5 text-slate-600 dark:text-slate-400 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-5 h-5 text-slate-600 dark:text-slate-400 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </nav>

    <main class="flex-1 overflow-hidden bg-slate-50 dark:bg-slate-900">
      <div id="stepContent" class="h-full overflow-y-auto px-5 py-6">
        <Steps />
      </div>
    </main>

    <footer class="h-[60px] flex items-center justify-center gap-4 px-5 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-700 flex-shrink-0">
      <button
        type="button"
        id="prevStepBtn"
        class="flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
        aria-label="Paso anterior"
      >
        <svg class="w-4 h-4 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Anterior</span>
      </button>

      <button
        type="button"
        id="stepJumpBtn"
        class="flex items-center gap-2 px-3 py-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
      >
        <span class="text-sm font-medium text-slate-700 dark:text-slate-300" id="stepIndicator">Paso 1 de 14</span>
        <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <button
        type="button"
        id="nextStepBtn"
        class="flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-500 hover:bg-indigo-600 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
        aria-label="Siguiente paso"
      >
        <span class="text-sm font-medium text-white">Siguiente</span>
        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </footer>
  </div>

  <div id="stepJumpModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" id="stepJumpBackdrop"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-4 w-[400px] max-h-[70vh] overflow-y-auto">
      <h3 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3 px-2">Ir a paso</h3>
      <div id="stepJumpList" class="space-y-1">
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const STORAGE_KEY = 'integration-guide-progress';
  const THEME_KEY = 'theme';

  function getProgress() {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored) {
      try {
        return JSON.parse(stored);
      } catch {
        return { currentStep: 1, completedSteps: [] };
      }
    }
    return { currentStep: 1, completedSteps: [] };
  }

  function saveProgress(progress) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(progress));
  }

  function goToStep(stepNumber) {
    if (stepNumber < 1 || stepNumber > 14) return;

    var stepContent = document.getElementById('stepContent');
    var steps = stepContent.querySelectorAll('.step-card');
    steps.forEach(function(step) {
      step.style.display = 'none';
    });

    var activeStep = stepContent.querySelector('.step-card[data-step="' + stepNumber + '"]');
    if (activeStep) {
      activeStep.style.display = 'block';
      activeStep.scrollTop = 0;
    }

    var stepIndicator = document.getElementById('stepIndicator');
    if (stepIndicator) {
      stepIndicator.textContent = 'Paso ' + stepNumber + ' de 14';
    }

    var progress = getProgress();
    progress.currentStep = stepNumber;
    saveProgress(progress);

    updateNavButtons(stepNumber);
    closeStepJumpModal();
  }

  function updateNavButtons(currentStep) {
    var prevBtn = document.getElementById('prevStepBtn');
    var nextBtn = document.getElementById('nextStepBtn');
    if (prevBtn) prevBtn.disabled = currentStep <= 1;
    if (nextBtn) nextBtn.disabled = currentStep >= 14;
  }

  function toggleTheme() {
    var html = document.documentElement;
    var isDark = html.classList.toggle('dark');
    localStorage.setItem(THEME_KEY, isDark ? 'dark' : 'light');
  }

  function openStepJumpModal() {
    var modal = document.getElementById('stepJumpModal');
    if (modal) {
      modal.classList.remove('hidden');
    }
  }

  function closeStepJumpModal() {
    var modal = document.getElementById('stepJumpModal');
    if (modal) {
      modal.classList.add('hidden');
    }
  }

  function init() {
    var stepContent = document.getElementById('stepContent');
    var stepJumpList = document.getElementById('stepJumpList');
    var steps = stepContent.querySelectorAll('.step-card');

    steps.forEach(function(step) {
      var stepNum = step.dataset.step;
      var stepTitle = step.dataset.title;
      var jumpItem = document.createElement('button');
      jumpItem.type = 'button';
      jumpItem.className = 'jump-item w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-left transition-colors bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 hover:bg-indigo-500 hover:text-white';
      jumpItem.dataset.step = stepNum;
      jumpItem.innerHTML = '<span class="flex-shrink-0 w-7 h-7 rounded-lg bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-300 text-xs font-bold flex items-center justify-center">' + stepNum + '</span><span class="text-sm font-medium truncate">' + stepTitle + '</span>';
      jumpItem.addEventListener('click', function() {
        goToStep(parseInt(this.dataset.step));
      });
      stepJumpList.appendChild(jumpItem);
    });

    var progress = getProgress();
    var currentStep = progress.currentStep || 1;

    var stepIndicator = document.getElementById('stepIndicator');
    if (stepIndicator) {
      stepIndicator.textContent = 'Paso ' + currentStep + ' de 14';
    }

    steps.forEach(function(step) {
      var stepNum = parseInt(step.dataset.step);
      if (stepNum !== currentStep) {
        step.style.display = 'none';
      }
    });

    document.getElementById('themeToggle').addEventListener('click', toggleTheme);
    document.getElementById('stepJumpBtn').addEventListener('click', openStepJumpModal);
    document.getElementById('stepJumpBackdrop').addEventListener('click', closeStepJumpModal);

    document.getElementById('prevStepBtn').addEventListener('click', function() {
      var progress = getProgress();
      if (progress.currentStep > 1) {
        goToStep(progress.currentStep - 1);
      }
    });

    document.getElementById('nextStepBtn').addEventListener('click', function() {
      var progress = getProgress();
      if (progress.currentStep < 14) {
        goToStep(progress.currentStep + 1);
      }
    });

    updateNavButtons(currentStep);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeStepJumpModal();
      } else if (e.key === 'ArrowLeft') {
        var progress = getProgress();
        if (progress.currentStep > 1) {
          goToStep(progress.currentStep - 1);
        }
      } else if (e.key === 'ArrowRight') {
        var progress = getProgress();
        if (progress.currentStep < 14) {
          goToStep(progress.currentStep + 1);
        }
      }
    });
  }

  init();
</script>